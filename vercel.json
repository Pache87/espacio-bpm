{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "usuarios.json"
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/logout", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}